# Frontend env (optional for local dev — Vite proxy handles /api automatically)

# Local: leave unset or use this (default in code is /api/v1 in dev)
# VITE_API_URL=/api/v1

# Production (Vercel): set in Vercel dashboard, not in GitHub
# VITE_API_URL=https://your-backend.onrender.com/api/v1

# Cloudinary (optional — enables upload + optimized avatars)
# VITE_CLOUDINARY_CLOUD_NAME=dd2ppni1h
# VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
